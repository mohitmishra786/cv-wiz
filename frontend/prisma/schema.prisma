// Prisma Schema for MatchQuill
// Career Resume Compiler Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// NextAuth.js Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Roles (authorization for admin-only routes)
// ============================================

enum Role {
  USER
  ADMIN
}

// ============================================
// Monetization (Stripe)
// ============================================
// NOTE: added by feat/monetization plumbing. See docs/monetization-decision.md
// for tier rationale. PRO is the only paid tier implemented today; TEAM is
// reserved for a future higher tier and intentionally unused so this stays
// a minimal, reversible change.

enum SubscriptionTier {
  FREE
  PRO
  TEAM
}

// Mirrors Stripe subscription lifecycle states we act on. NONE means the
// user has never started a paid subscription (default/free state).
enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
}

// ============================================
// User Model (Extended for MatchQuill)
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  /// Authorization role. Defaults to USER. Only ADMIN may access audit logs.
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // MatchQuill Profile Relations
  experiences      Experience[]
  projects         Project[]
  educations       Education[]
  skills           Skill[]
  publications     Publication[]
  coverLetters     CoverLetter[]
  documentImages   DocumentImage[]
  feedbacks        Feedback[]
  settings         UserSettings?
  auditLogs        AuditLog[] @relation("AuditLogs")
  
  // New Features
  jobApplications  JobApplication[]
  resumeVersions   ResumeVersion[]
  sharedResumes    SharedResume[]

  @@index([role])
}

// ============================================
// Career Data Models
// ============================================

model Experience {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String    @db.Text
  highlights  String[]  @default([])
  keywords    String[]  @default([])
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model Project {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String    @db.Text
  url          String?
  startDate    DateTime?
  endDate      DateTime?
  technologies String[]  @default([])
  highlights   String[]  @default([])
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model Education {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  field       String
  startDate   DateTime
  endDate     DateTime?
  gpa         Float?
  honors      String[]  @default([])
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model Skill {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String   // e.g., "Programming", "Tools", "Soft Skills"
  proficiency String?  // e.g., "Expert", "Intermediate", "Beginner"
  yearsExp    Int?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@unique([userId, name])
}

model Publication {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  venue     String   // Journal/Conference name
  authors   String[]
  date      DateTime
  url       String?
  doi       String?
  abstract  String?  @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedTemplate  String   @default("experience-skills-projects")
  resumePreferences Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // --- Monetization (Stripe) ---
  // Defaults to FREE/NONE so every existing row stays on the free tier with
  // no behavior change when this migration is applied.
  subscriptionTier     SubscriptionTier   @default(FREE)
  subscriptionStatus   SubscriptionStatus @default(NONE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)

  @@index([subscriptionTier])
}

model CoverLetter {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Letter body only (greeting through signature) — not the header contact block
  content     String   @db.Text
  jobTitle    String?
  companyName String?
  /// Structured contact / meta fields extracted separately from the body
  email       String?
  phone       String?
  website     String?
  location    String?
  linkedin    String?
  github      String?
  recipientName String?
  applicantName String?
  /// Optional data-URL thumbnails extracted from an uploaded letter PDF
  imageUrls   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

/// Images extracted from resume / cover-letter uploads (profile photos, logos).
/// Stored as data URLs (bounded size) so no object storage is required.
model DocumentImage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "resume" | "cover-letter"
  source    String
  mimeType  String
  /// data:image/...;base64,... (capped at extraction time)
  dataUrl   String   @db.Text
  width     Int?
  height    Int?
  isProfile Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isProfile])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  rating    Int
  comment   String   @db.Text
  category  String   // e.g., "UI", "AI", "Bug", "Other"
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================
// New Features
// ============================================

// Job Application Tracking System (#70)
model JobApplication {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     String
  position    String
  status      String   @default("applied") // applied, interviewing, offer, rejected
  appliedDate DateTime @default(now())
  notes       String?  @db.Text
  url         String?
  salary      String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Resume Version History (#68)
model ResumeVersion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?  // Optional name like "Google Application"
  snapshot    Json     // Complete snapshot of profile data
  createdAt   DateTime @default(now())

  @@index([userId])
}

// Shared Resumes (#69)
model SharedResume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique // URL friendly identifier
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  snapshot    Json?    // Optional snapshot, otherwise uses live data
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}


// ============================================
// Audit Logging
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  // Who performed the action
  user        User?    @relation("AuditLogs", fields: [userId], references: [id], onDelete: SetNull)
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entityType  String   // User, Experience, Skill, etc.
  entityId    String?  // ID of the affected entity
  oldValues   Json?    // Previous values (for updates/deletes)
  newValues   Json?    // New values (for creates/updates)
  ipAddress   String?  // IP address of the request
  userAgent   String?  // User agent string
  requestId   String?  // Request ID for tracing
  metadata    Json?    // Additional context
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
